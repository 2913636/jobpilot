# JobPilot Environment Configuration
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=jobpilot
POSTGRES_PASSWORD=jobpilot_secret
POSTGRES_DB=jobpilot
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Milvus ---
MILVUS_HOST=milvus
MILVUS_PORT=19530

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jobpilot

# --- LiveKit ---
LIVEKIT_URL=http://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# --- Temporal ---
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233

# --- NATS ---
NATS_URL=nats://nats:4222

# --- JWT / Auth ---
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Service Ports ---
USER_SERVICE_PORT=8001
RESUME_SERVICE_PORT=8002
MATCH_SERVICE_PORT=8003
APPLY_SERVICE_PORT=8004
INTERVIEW_SERVICE_PORT=8005
AGENT_SERVICE_PORT=8006

# --- SMTP ---
SMTP_ENABLED=false

# --- CORS ---
CORS_ORIGIN=http://localhost:3000
PRODUCTION_DOMAIN=https://jobpilot.example.com

# --- OpenTelemetry ---
OTEL_EXPORTER_JAEGER_ENDPOINT=http://jaeger:14268/api/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SDK_DISABLED=false

# --- AI & External APIs ---
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPGRAM_API_KEY=
TRANSCRIPTION_PROVIDER=mock

# --- TTS ---
TTS_PROVIDER=mock
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastasia

# --- PostgreSQL host override (for non-Docker environments) ---
POSTGRES_HOST=postgres
