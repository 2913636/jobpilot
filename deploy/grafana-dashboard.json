{
  "dashboard": {
    "title": "JobPilot - Business Overview",
    "uid": "jobpilot-business",
    "panels": [
      {
        "title": "User Registrations",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
        "targets": [{ "expr": "user_registrations_total", "legendFormat": "Total" }]
      },
      {
        "title": "Resumes Parsed",
        "type": "stat",
        "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
        "targets": [{ "expr": "resumes_parsed_total", "legendFormat": "Total" }]
      },
      {
        "title": "Applications Created",
        "type": "stat",
        "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
        "targets": [{ "expr": "applications_created_total", "legendFormat": "Total" }]
      },
      {
        "title": "Interviews Completed",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
        "targets": [{ "expr": "interviews_completed_total", "legendFormat": "Total" }]
      },
      {
        "title": "Applications Submitted (Rate)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "targets": [
          { "expr": "rate(applications_submitted_total[5m])", "legendFormat": "Submit Rate" },
          { "expr": "rate(applications_created_total[5m])", "legendFormat": "Create Rate" }
        ]
      },
      {
        "title": "Apdex Score by Endpoint",
        "type": "gauge",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "(apdex_satisfied_total + apdex_tolerating_total / 2) / apdex_total"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 0.7, "color": "yellow" },
                { "value": 0.85, "color": "green" },
                { "value": 0.94, "color": "green" }
              ]
            },
            "max": 1, "min": 0
          }
        }
      },
      {
        "title": "Service Health",
        "type": "stat",
        "gridPos": { "x": 0, "y": 12, "w": 24, "h": 4 },
        "targets": [
          { "expr": "service_health_postgres", "legendFormat": "PostgreSQL" },
          { "expr": "service_health_redis", "legendFormat": "Redis" },
          { "expr": "service_health_elasticsearch", "legendFormat": "ES" },
          { "expr": "service_health_milvus", "legendFormat": "Milvus" },
          { "expr": "service_health_neo4j", "legendFormat": "Neo4j" }
        ]
      },
      {
        "title": "Match Evaluations",
        "type": "stat",
        "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
        "targets": [{ "expr": "matches_evaluated_total", "legendFormat": "Total" }]
      },
      {
        "title": "Jobs Crawled",
        "type": "stat",
        "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
        "targets": [{ "expr": "jobs_crawled_total", "legendFormat": "Total" }]
      }
    ],
    "templating": {
      "list": []
    },
    "time": { "from": "now-6h", "to": "now" },
    "refresh": "30s"
  }
}
